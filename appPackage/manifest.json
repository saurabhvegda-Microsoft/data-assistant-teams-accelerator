{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.1.1",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "Data Assistant Test Dev",
    "websiteUrl": "https://github.com/saurabhvegda-Microsoft/data-assistant-teams-accelerator",
    "privacyUrl": "https://github.com/saurabhvegda-Microsoft/data-assistant-teams-accelerator",
    "termsOfUseUrl": "https://github.com/saurabhvegda-Microsoft/data-assistant-teams-accelerator"
  },
  "name": {
    "short": "Data Assistant",
    "full": "Data Assistant Test Dev"
  },
  "description": {
    "short": "Ask financial data questions in Teams",
    "full": "A conversational test bot for financial data queries. Ask natural language questions and receive structured data responses as Adaptive Cards."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078D4",
  "bots": [
    {
      "botId": "${{BOT_ID}}",
      "scopes": [
        "personal"
      ],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": [
            "personal"
          ],
          "commands": [
            {
              "title": "help",
              "description": "Show what I can help with"
            },
            {
              "title": "revenue",
              "description": "Get revenue data"
            },
            {
              "title": "margins",
              "description": "Get margin analysis"
            }
          ]
        }
      ]
    }
  ],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": [],
  "webApplicationInfo": {
    "id": "${{BOT_ID}}",
    "resource": "${{AAD_APPLICATION_ID_URI}}"
  }
}
