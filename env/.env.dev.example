# Data Assistant Teams Bot — Dev Environment
# Copy this file to .env.dev and fill in your values

# Azure Bot Registration (auto-populated by `atk provision`)
BOT_ID=
BOT_PASSWORD=
TEAMS_APP_ID=
# SingleTenant bots only: set to the Entra tenant GUID where the App Registration lives.
# Leave empty for MultiTenant (deprecated) or UAMI deployments.
tenantId=

# Data Agent API Configuration
# Set USE_MOCK_CLIENT=false and provide DATA_AGENT_API_BASE_URL to use real API
USE_MOCK_CLIENT=true
DATA_AGENT_API_BASE_URL=
DATA_AGENT_API_KEY=

# Data Agent client selector: mock | rest | mcp
# When set, overrides USE_MOCK_CLIENT. Use "mcp" to talk to the Data Agent as an
# MCP server (Streamable HTTP) instead of a plain REST API.
DATA_AGENT_CLIENT=
# MCP endpoint (when DATA_AGENT_CLIENT=mcp); falls back to DATA_AGENT_API_BASE_URL.
MCP_ENDPOINT_URL=
MCP_TOOL_NAME=query
# Stream interim progress ("thoughts") to Teams in personal chat. true | false
STREAMING_ENABLED=true

# Azure Resources (auto-populated by `atk provision`)
APP_SERVICE_NAME=
BOT_SERVICE_NAME=

# Observability (auto-populated by `atk provision` or from Azure Portal)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Security
# Set DISABLE_AUTH=true for local development without JWT validation
DISABLE_AUTH=true

# Access Control
# Mode: "disabled" | "allowlist" | "entra"
ACCESS_CONTROL_MODE=disabled
ACCESS_CONTROL_ALLOWLIST=
ACCESS_CONTROL_ENTRA_GROUP_ID=
ACCESS_CONTROL_CACHE_TTL_MS=60000

# Server
PORT=3978
