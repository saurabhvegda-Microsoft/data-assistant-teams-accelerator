# Data Assistant Teams Bot — Dev Environment
# Copy this file to .env.dev and fill in your values

# Azure Bot Registration (auto-populated by `atk provision`)
BOT_ID=
BOT_PASSWORD=
TEAMS_APP_ID=
# SingleTenant bots only: set to the Entra tenant GUID where the App Registration lives.
# Leave empty for MultiTenant (deprecated) or UAMI deployments.
tenantId=

# Data Agent API Configuration
# Set USE_MOCK_CLIENT=false and provide DATA_AGENT_API_BASE_URL to use real API
USE_MOCK_CLIENT=true
DATA_AGENT_API_BASE_URL=
DATA_AGENT_API_KEY=

# Data Agent client selector: mock | rest | mcp
# When set, overrides USE_MOCK_CLIENT. Use "mcp" to talk to the Data Agent as an
# MCP server (Streamable HTTP) instead of a plain REST API.
DATA_AGENT_CLIENT=
# MCP endpoint (when DATA_AGENT_CLIENT=mcp); falls back to DATA_AGENT_API_BASE_URL.
MCP_ENDPOINT_URL=
MCP_TOOL_NAME=query
# Stream interim progress ("thoughts") to Teams in personal chat. true | false
STREAMING_ENABLED=true
# Relay EACH MCP progress step as its own update (verbose). Default false = a
# single "Working on your question…" indicator until the result is ready.
STREAMING_THOUGHTS_ENABLED=false
# Render Teams native Adaptive Card charts (Chart.Line / Chart.VerticalBar) for
# time-series. true | false. When false, falls back to a static chart image.
NATIVE_CHARTS_ENABLED=true
# Expose an "Open interactive chart" action that opens a fully-interactive
# (zoom/hover/pan) chart web view served by the bot at /charts/:id. true | false.
INTERACTIVE_CHARTS_ENABLED=false
# Public base URL used to build the interactive-chart link (the bot's public
# FQDN or dev tunnel). Falls back to http://localhost:PORT when unset.
PUBLIC_BASE_URL=
# Maintain conversation history server-side (MCP/Data Agent session). true | false.
# When true the bot sends a stable session id per chat and offers a "New
# conversation" reset; false keeps every query single-turn / stateless.
CONVERSATION_HISTORY_ENABLED=false

# Azure Resources (auto-populated by `atk provision`)
APP_SERVICE_NAME=
BOT_SERVICE_NAME=

# Observability (auto-populated by `atk provision` or from Azure Portal)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Security
# Set DISABLE_AUTH=true for local development without JWT validation
DISABLE_AUTH=true

# Access Control
# Mode: "disabled" | "allowlist" | "entra"
ACCESS_CONTROL_MODE=disabled
ACCESS_CONTROL_ALLOWLIST=
ACCESS_CONTROL_ENTRA_GROUP_ID=
ACCESS_CONTROL_CACHE_TTL_MS=60000

# User authentication (per-user JWT to the Data Agent via Teams SSO + OBO).
# Off by default. When enabled, the bot exchanges the user's Teams SSO token for
# a Data Agent-scoped token and sends it as the Authorization bearer.
USER_AUTH_ENABLED=false
# OBO confidential client (defaults to BOT_ID / BOT_PASSWORD / tenantId).
AAD_CLIENT_ID=
AAD_CLIENT_SECRET=
AAD_TENANT_ID=
# Scope requested for the Data Agent API, e.g. api://<data-agent-app-id>/access_as_user
DATA_AGENT_SCOPE=
# Application ID URI exposed by the bot for Teams SSO (manifest webApplicationInfo.resource),
# e.g. api://<your-domain>/<bot-app-id>
AAD_APPLICATION_ID_URI=

# Server
PORT=3978
