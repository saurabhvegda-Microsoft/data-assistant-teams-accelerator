# Data Assistant Teams Bot — Production Environment
# Copy this file to .env.prod and fill in your values

# Azure Bot Registration (auto-populated by `atk provision`)
BOT_ID=
BOT_PASSWORD=
TEAMS_APP_ID=

# Data Agent API Configuration
USE_MOCK_CLIENT=false
DATA_AGENT_API_BASE_URL=https://your-data-agent.example.com
DATA_AGENT_API_KEY=

# Azure Resources (auto-populated by `atk provision`)
APP_SERVICE_NAME=
BOT_SERVICE_NAME=

# Observability (auto-populated by `atk provision`)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Access Control
# Mode: "disabled" | "allowlist" | "entra"
ACCESS_CONTROL_MODE=entra
ACCESS_CONTROL_ALLOWLIST=
ACCESS_CONTROL_ENTRA_GROUP_ID=<your-entra-security-group-id>
ACCESS_CONTROL_CACHE_TTL_MS=60000

# Server
PORT=3978
