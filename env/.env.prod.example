# Data Assistant Teams Bot — Production Environment
# Copy this file to .env.prod and fill in your values

# Azure Bot Registration (auto-populated by `atk provision`)
BOT_ID=
BOT_PASSWORD=
TEAMS_APP_ID=

# Data Agent API Configuration
USE_MOCK_CLIENT=false
DATA_AGENT_API_BASE_URL=https://your-data-agent.example.com
DATA_AGENT_API_KEY=

# Data Agent client selector: mock | rest | mcp
DATA_AGENT_CLIENT=mcp
MCP_ENDPOINT_URL=https://your-data-agent.example.com/mcp
MCP_TOOL_NAME=query
STREAMING_ENABLED=true
STREAMING_THOUGHTS_ENABLED=false
NATIVE_CHARTS_ENABLED=true
# Interactive chart web view: adds an "Open interactive chart" action.
INTERACTIVE_CHARTS_ENABLED=true
# Public base URL used to build the interactive-chart link (bot's public FQDN).
PUBLIC_BASE_URL=https://your-data-assistant-bot.example.com
CONVERSATION_HISTORY_ENABLED=true

# Azure Resources (auto-populated by `atk provision`)
APP_SERVICE_NAME=
BOT_SERVICE_NAME=

# Observability (auto-populated by `atk provision`)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Access Control
# Mode: "disabled" | "allowlist" | "entra"
ACCESS_CONTROL_MODE=entra
ACCESS_CONTROL_ALLOWLIST=
ACCESS_CONTROL_ENTRA_GROUP_ID=<your-entra-security-group-id>
ACCESS_CONTROL_CACHE_TTL_MS=60000

# User authentication (per-user JWT to the Data Agent via Teams SSO + OBO).
USER_AUTH_ENABLED=true
# OBO confidential client (defaults to BOT_ID / BOT_PASSWORD / tenantId).
AAD_CLIENT_ID=
AAD_CLIENT_SECRET=
AAD_TENANT_ID=
DATA_AGENT_SCOPE=api://<data-agent-app-id>/access_as_user
AAD_APPLICATION_ID_URI=api://<your-domain>/<bot-app-id>

# Server
PORT=3978
